# Example nginx site config for P4_web_wrap production.
# Install on the server:
#   sudo cp deploy/nginx-p4.conf.example /etc/nginx/sites-available/p4
#   sudo ln -sf /etc/nginx/sites-available/p4 /etc/nginx/sites-enabled/p4
#   sudo rm -f /etc/nginx/sites-enabled/default
#   sudo nginx -t && sudo systemctl reload nginx
#
# Replace YOUR_DOMAIN_OR_IP with the public hostname or use "_" for any host.

server {
    listen 80;
    server_name _;

    # Required for browser folder import. Default nginx limit is 1 MB.
    client_max_body_size 512m;

    root /srv/p4/app/P4_web_wrap/P4_web_client;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /reduced/ {
        try_files $uri $uri/ /reduced/index.html;
    }

    location /api/ {
        client_max_body_size 512m;
        proxy_pass http://127.0.0.1:8000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Large project folder uploads can take several minutes.
        proxy_connect_timeout 600s;
        proxy_send_timeout 600s;
        proxy_read_timeout 600s;
        send_timeout 600s;
    }
}
