# Copy to deploy/config.env (local) and/or /srv/p4/config.env (server).

# --- Direct deploy (deploy.sh, upload_update.sh, push_update.sh) ---
P4_DEPLOY_HOST=ubuntu@YOUR_SERVER_IP
# P4_DEPLOY_SSH_KEY=$HOME/.ssh/id_rsa
# P4_UPLOAD_HOST=ubuntu@YOUR_SERVER_IP   # alias for upload_update.sh

# Local paths (defaults: repo root and ../P4_app)
# P4_LOCAL_WEB_WRAP=/path/to/P4_web_wrap
# P4_LOCAL_P4_APP=/path/to/P4_app

# --- Server layout ---
P4_SRV_ROOT=/srv/p4
P4_APP_ROOT=/srv/p4/app
P4_INCOMING_ROOT=/srv/p4/incoming
P4_UPDATE_STAGING=/srv/p4/incoming/updates
P4_BACKUP_ROOT=/srv/p4/backups

P4_REMOTE_WEB_WRAP=/srv/p4/app/P4_web_wrap
P4_REMOTE_P4_APP=/srv/p4/app/P4_app
P4_WEB_WRAP=/srv/p4/app/P4_web_wrap
P4_LEGACY_APP=/srv/p4/app/P4_app

# SFTP upload user (created by setup_server.sh)
P4_DEPLOY_USER=p4deploy
P4_DEPLOY_GROUP=p4deploy
P4_APP_USER=ubuntu

# Docker
P4_LEGACY_RUNNER_IMAGE=p4-legacy-runner
P4_LEGACY_BASE_IMAGE=s.egorkin/heinz_p4:latest

# Services (leave empty to skip restart)
P4_WEB_SERVICE=p4-web
P4_NGINX_SERVICE=nginx

# Post-deploy verification
P4_HEALTH_URL=http://127.0.0.1:8000/api/health
