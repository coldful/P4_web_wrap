P4_WEB_APP_NAME=P4 Web
P4_WEB_ENVIRONMENT=local
P4_WEB_DATABASE_URL=sqlite+aiosqlite:///./var/p4_web.db
P4_WEB_STORAGE_BACKEND=local
P4_WEB_LOCAL_STORAGE_ROOT=./var/storage
P4_WEB_WORKSPACE_ROOT=./var/workspaces
P4_WEB_LEGACY_P4_APP_PATH=../../P4_app
P4_WEB_ENABLE_LEGACY_RUNNER=false
P4_WEB_LEGACY_PYTHON_EXECUTABLE=python2.7
# Optional override for container/script based execution.
# Placeholders: {python}, {interface}, {project_path}, {operation}, {language}, {app_path}
# For generic CLI/container wrappers, the runner also exports P4_WEB_JOB_PARAMETERS as JSON.
# Example:
# P4_WEB_LEGACY_RUNNER_COMMAND=docker run --rm -e P4_WEB_JOB_PARAMETERS -e P4_WEB_JOB_KIND -v /abs/P4_app:/opt/P4_app:ro -v {project_path}:/work/project p4-legacy-runner run-web-job --operation {operation} --project-path /work/project --language {language}
# P4_WEB_LEGACY_RUNNER_COMMAND=
P4_WEB_LEGACY_RUNNER_TIMEOUT_SECONDS=3600
P4_WEB_LEGACY_PDF_ARTIFACT_GLOBS=*.pdf,**/*.pdf
P4_WEB_CORS_ORIGINS=http://localhost:5173,http://localhost:8000
# Production example (when frontend talks directly to port 8000):
# P4_WEB_CORS_ORIGINS=http://YOUR_SERVER,https://YOUR_DOMAIN
